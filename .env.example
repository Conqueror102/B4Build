# =============================================================================
# AI Build Advisor - Environment Variables (example)
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Backend ---
APP_ENV=development
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_REASONING_MODEL=gpt-4o

# Tavily (web search tool, used by Phase 0 and Red Team)
TAVILY_API_KEY=tvly-...

# GitHub (Phase 3 repo search — optional; without it, unauthenticated API is strict rate limits / may return 0 after 403)
GITHUB_TOKEN=

# LangSmith (tracing, optional — free tier is fine for dev)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=ai-build-advisor-dev
# Self-hosted LangSmith only (omit for cloud smith.langchain.com):
# LANGCHAIN_ENDPOINT=https://your-langsmith-host/api/v1

# Database (Phase 3+)
DATABASE_URL=postgresql+asyncpg://advisor:advisor@localhost:5432/advisor

# Redis (Phase 5+, in-memory limiter used until then)
REDIS_URL=redis://localhost:6379/0

# Cost guardrails (USD)
DAILY_OPENAI_SPEND_CAP=10.0
PER_REQUEST_COST_CAP=0.50

# Sentry (Phase 7)
SENTRY_DSN=

# Auth (Phase 5+)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# CORS (production / ECS: set via Terraform cors_allow_origins as JSON array)
# Example: CORS_ALLOW_ORIGINS=["https://main.xxx.amplifyapp.com"]
# Omit locally to use settings.py defaults (localhost).

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
